{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 100,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "sortImports": true,
    "sortPackageJson": true,
    "ignorePatterns": ["**/dist/**", "**/node_modules/**"],
    "overrides": [
        {
            "files": ["*.{yml,yaml}"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
