{
    "name": "github-cursor-stats",
    "version": "1.0.1",
    "description": "Sync Cursor tab and composer usage from your local database to a GitHub profile README",
    "keywords": [
        "bun",
        "cli",
        "cursor",
        "cursor-ide",
        "github-profile",
        "stats"
    ],
    "homepage": "https://github.com/0xr3ngar/cursor-stats#readme",
    "bugs": {
        "url": "https://github.com/0xr3ngar/cursor-stats/issues"
    },
    "license": "MIT",
    "author": "0xr3ngar",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/0xr3ngar/cursor-stats.git"
    },
    "bin": {
        "cursor-stats": "./dist/index.js"
    },
    "files": [
        "dist",
        "docs",
        "README.md",
        "LICENSE",
        "NOTICE"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "bun run src/index.ts",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "build": "bunli build",
        "release": "bunli release",
        "generate": "bunli generate",
        "prepublishOnly": "bun run build",
        "test": "bun test",
        "typecheck": "tsgo --noEmit",
        "knip": "knip"
    },
    "dependencies": {
        "@bunli/core": "0.9.1",
        "@resvg/resvg-js": "^2.6.2",
        "chalk": "5.6.2",
        "commander": "15.0.0",
        "ora": "9.4.0",
        "satori": "^0.26.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@bunli/test": "^0.6.0",
        "@tsconfig/bun": "1.0.10",
        "@types/bun": "^1.3.14",
        "@typescript/native-preview": "^7.0.0-dev.20260613.1",
        "bunli": "^0.9.1",
        "knip": "^6.16.1",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "oxlint-tsgolint": "^0.23.0",
        "typescript": "^5.0.0"
    },
    "engines": {
        "bun": ">=1.0.0"
    },
    "bunli": {
        "entry": "./src/index.ts",
        "outDir": "./dist"
    }
}
