{
    "name": "cursor-stats",
    "version": "0.1.0",
    "description": "A CLI built with Bunli",
    "author": "",
    "bin": {
        "cursor-stats": "./dist/index.js"
    },
    "type": "module",
    "scripts": {
        "dev": "bun run src/index.ts",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "build": "bunli build",
        "test": "bun test",
        "typecheck": "tsgo --noEmit",
        "knip": "knip"
    },
    "dependencies": {
        "@bunli/core": "0.9.1",
        "@resvg/resvg-js": "^2.6.2",
        "@typescript/native-preview": "^7.0.0-dev.20260613.1",
        "satori": "^0.26.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@bunli/test": "^0.6.0",
        "@tsconfig/bun": "1.0.10",
        "@types/bun": "^1.3.14",
        "bunli": "^0.9.1",
        "knip": "^6.16.1",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "oxlint-tsgolint": "^0.23.0",
        "typescript": "^5.0.0"
    },
    "bunli": {
        "entry": "./src/index.ts",
        "outDir": "./dist"
    }
}
